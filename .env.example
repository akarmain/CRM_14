# Переменные для `docker compose up` (корневой docker-compose.yml).
# Скопируй в `.env` и при необходимости поменяй значения:
#   cp .env.example .env

# --- Режим хранилища ---
# postgres — рабочий режим по умолчанию (поднимается сервисом postgres из compose)
# memo     — in-memory, без БД (данные не сохраняются между перезапусками)
# 1c       — внешний 1С HTTP-сервис (нужен запущенный 1С, см. документацию)
STORAGE_MODE=postgres

# --- PostgreSQL ---
POSTGRES_DB=mini_crm_simple
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/mini_crm_simple

# --- Backend ---
LOG_LEVEL=INFO
SESSION_SECRET=change-me-in-production
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SESSION_HTTPS_ONLY=false

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000/api/v1

# --- Опционально: режим 1С ---
# STORAGE_MODE=1c
# ONEC_BASE_URL=http://host.docker.internal:8314/Infobase/hs/http_methods
# ONEC_TIMEOUT_SECONDS=10
# ONEC_MAX_RETRIES=3
# ONEC_RETRY_BACKOFF_SECONDS=0.35
